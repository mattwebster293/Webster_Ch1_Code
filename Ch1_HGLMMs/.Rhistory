alpha   <- 0.5   # baseline inundation at mean Flow, mean TopographicOpenness, no dams
beta1   <- 0.0125   # linear effect of Flow (per 1 SD) in undammed reaches
beta2   <- -0.1  # quadratic effect of Flow (concave-down)
eta1    <- 0.5   # additional linear effect of Flow when dams present
eta2    <- 0.1   # additional quadratic effect when dams present
lambda1 <- 0.5   # effect of TopographicOpenness (per 1 SD)
TopographicOpenness <- 0  # fixed at mean for plotting
prop_inund_fun <- function(Flow, DamPresence, TopographicOpenness = 0) {
alpha +
beta1 * Flow +
beta2 * Flow^2 +
eta1 * Flow * DamPresence +
eta2 * Flow^2 * DamPresence +
lambda1 * TopographicOpenness
}
# Flow gradient in SD units
flow_seq <- seq(-2, 2, length.out = 200)
dat <- expand.grid(
Flow = flow_seq,
DamPresence = c(0, 1)
) |>
mutate(
Prop_Inund = prop_inund_fun(Flow, DamPresence, TopographicOpenness),
DamPresence = factor(DamPresence, levels = c(0, 1),
labels = c("No dams", "Dams present")),
Prop_Inund = pmin(pmax(Prop_Inund, 0), 1)  # clamp to [0,1] for plotting
)
ggplot(dat, aes(x = Flow, y = Prop_Inund, color = DamPresence)) +
geom_line(linewidth = 1.1) +
scale_color_manual(values = c("No dams" = "grey30", "Dams present" = "steelblue")) +
coord_cartesian(ylim = c(0, 1)) +
labs(
x = "Flow (z-standardized)",
y = "Proportion of riparian area inundated",
color = "Beaver dams",
title = "Expected effect of beaver dams on riparian inundation across standardized flow"
) +
theme_minimal(base_size = 13)
