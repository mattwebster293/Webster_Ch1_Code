"b_stream",
"b_year",
"b_event",
"sigma",
"eta_stream",
"eta_event",
"eta_cluster",
"sigma_stream",
"sigma_b_stream",
"sigma_b_year",
"sigma_b_event",
"sigma_event",
"sigma_cluster"
)
nchains <- 3
nthin <- 10
niter <- 20000
nburn <- 5000
m3_HGLM_SWA <- jags(data = m3_data_list,
inits = m3inits,
parameters.to.save = parameters_m3,
model.file = "HGLMM_damPres.jags",
parallel = T,
n.chains = nchains,
n.thin = nthin,
n.iter = niter,
n.burnin = nburn)
