fill = "Sample Window Type",
title = "Riparian Area by Dam Status",
subtitle = "Willow Creek 2019"
) +
theme_bw(base_size = 14)
#####
# TO
ggplot(wc19_lateSummer_Sample_Long,
aes(x = window_type,
y = TO,
fill = window_type)) +
geom_violin() +
scale_fill_manual(values = c("undammed" = "steelblue",
"dammed"   = "brown")) +
labs(
x = "Time period (t)",
y = "Topographic Openness",
fill = "Sample Window Type",
title = "TO by Dam Status",
subtitle = "Willow Creek 2019"
) +
theme_bw(base_size = 14)
#####
# vegArea
ggplot(wc19_lateSummer_Sample_Long,
aes(x = window_type,
y = VA,
fill = window_type)) +
geom_violin() +
scale_fill_manual(values = c("undammed" = "steelblue",
"dammed"   = "brown")) +
labs(
x = "Time period (t)",
y = "Vegetation Area m^2",
fill = "Sample Window Type",
title = "vegArea by Dam Status",
subtitle = "Willow Creek 2019"
) +
theme_bw(base_size = 14)
#####
# NDVI
ggplot(wc19_lateSummer_Sample_Long,
aes(x = window_type,
y = NDVI,
fill = window_type)) +
geom_violin() +
scale_fill_manual(values = c("undammed" = "steelblue",
"dammed"   = "brown")) +
labs(
x = "Time period (t)",
y = "NDVI",
fill = "Sample Window Type",
title = "Veg NDVI by Dam Status",
subtitle = "Willow Creek 2019"
) +
theme_bw(base_size = 14)
