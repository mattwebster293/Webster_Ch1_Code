TP_ID,
window_type,
catchment_km2,
riparian_area_m2,
TO,
p_mean,
f_mean,
dam_count_beav_all,
dam_count_beav_conf,
dam_count_ant,
isAnthro,
dam_intensity,
SWA_t1,
SWA_t2,
SWA_t3,
SWA_t4,
SWA_t5,
SWA_t6,
SWA_t7,
SWA_t8,
vegArea_t5,
vegArea_t6,
vegArea_t7,
