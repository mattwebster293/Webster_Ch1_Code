lt21_final_long <- lt21_final %>%
  pivot_longer(
    cols = starts_with("sum_SWA_t"),
    names_to = "time_period",
    values_to = "SWA"
  ) %>%
  mutate(
    t = as.factor(gsub("sum_SWA_t", "", time_period))
  )

