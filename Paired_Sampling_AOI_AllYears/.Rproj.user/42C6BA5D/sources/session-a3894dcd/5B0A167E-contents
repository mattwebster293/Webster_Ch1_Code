DEFINE PAIRED UNDAMMED REACHES:
----

    - Undammed sample reaches must be:
      - interspersed between dammed reaches
      - (>=) 500m from nearest dam
      - 'paired' with a nearby dam cluster
      - (>=) 250m from nearest undammed (forced thinning post-pairing)

```{r,echo=FALSE}
lt21_dam_min <- min(lt21_dammed_df$TP_ID) #Find min/max dammed TP_ID to intersperse undammed among
lt21_dam_max <- max(lt21_dammed_df$TP_ID)


#Determine 500m buffers up and down from each dammed cluster; NO 'undammed' within this zone
lt21_dam_influence_500 <- unique(unlist(
  apply(lt21_dammed_df[, c("cluster_start", "cluster_end")], 1, function(row) {
    seq(row["cluster_start"] - 50,
        row["cluster_end"]   + 50)
  })
)) 

#Get all available Riparian Polygons (excludes reservoir-affected)
lt21_all_tpids <- sort(unique(lt21_SWmax$TP_ID))  

#Ensure interspersion of undammed within dammed sites
lt21_inRange_tpids <- lt21_all_tpids[lt21_all_tpids >= lt21_dam_min & lt21_all_tpids <= lt21_dam_max]

#Get only riparian polygons that are not inside the dam or anthro influence zone (cluster+-500m)
lt21_eligible_undammed_tpids <- lt21_inRange_tpids[(!lt21_inRange_tpids %in% lt21_dam_influence_500) &
                                                     (!lt21_inRange_tpids %in% lt21_anthro_influence_500)]

#Get cluster start point for each dammed cluster
lt21_dam_clusters <- lt21_dammed_df %>%
  distinct(clusterID_seq, 
           cluster_start, 
           cluster_end, 
           cluster_dam_count) %>%
  arrange(clusterID_seq)


#PROXIMITY BASED PAIRING
#Define available undammed reaches to sample
lt21_remaining_undammed <- lt21_eligible_undammed_tpids

#Define undammed reaches that have been matched with dammed clusters
lt21_assigned_matches <- integer(nrow(lt21_dam_clusters)) #get 1 undammed for each dammed

# Iterate through dammed clusters
for (i in seq_len(nrow(lt21_dam_clusters))) {
  # find cluster start
  cs <- lt21_dam_clusters$cluster_start[i]
  
  # find nearest remaining undammed site
  idx <- which.min(abs(lt21_remaining_undammed - cs))
  match <- lt21_remaining_undammed[idx]
  
  lt21_assigned_matches[i] <- match
  
  # remove it so it cannot be reused
  lt21_remaining_undammed <- lt21_remaining_undammed[-idx]
}

#Create table to visualize and gut check matches
lt21_pairings <- lt21_dam_clusters %>%
  mutate(undam_match = lt21_assigned_matches) %>%
  left_join(lt21_dammed_df %>%
              group_by(clusterID_seq) %>%
              summarise(dam_window_length_tpid = max(cluster_end) - min(cluster_start),
                        .groups = "drop"),
            by = "clusterID_seq") %>%
  mutate(undam_window_start = undam_match,
         undam_window_end   = undam_match + dam_window_length_tpid
  )

# THIN UNDAMMED WINDOWS *AFTER* WINDOW LENGTH IS KNOWN ---------------

lt21_pairings <- lt21_pairings %>% arrange(undam_window_start)

thinned <- list()
last_end <- -Inf

for (i in seq_len(nrow(lt21_pairings))) {
  start_i <- lt21_pairings$undam_window_start[i]
  end_i   <- lt21_pairings$undam_window_end[i]
  
  if (start_i >= last_end + 25) {   # enforce 250-m spacing
    thinned <- append(thinned, i)   # NOTE: ^ no diff. than 100-m on lt21
    last_end <- end_i
  }
}

lt21_pairings <- lt21_pairings[unlist(thinned), ]

# Now combine dammed and undammed windows into a unified table and select only those windows from the main dataframe
lt21_dammed_windows <- lt21_pairings %>%
  transmute(
    clusterID_seq,
    window_type = "dammed",
    window_start = cluster_start,
    window_end   = cluster_end,
    window_length = (window_end - window_start)*10,
    dam_intensity = cluster_dam_count
  )

lt21_undammed_windows <- lt21_pairings %>% 
  transmute(
    clusterID_seq,
    window_type = "undammed",
    window_start = undam_match,
    window_end   = undam_match + dam_window_length_tpid,
    window_length = dam_window_length_tpid * 10,
    dam_intensity = 0
  )

lt21_all_windows <- bind_rows(
  lt21_dammed_windows,
  lt21_undammed_windows
)

lt21_sampled <- lt21_SWmax %>%
  cross_join(lt21_all_windows) %>%   # explicit Cartesian join
  filter(
    TP_ID >= window_start,
    TP_ID <= window_end
  )
