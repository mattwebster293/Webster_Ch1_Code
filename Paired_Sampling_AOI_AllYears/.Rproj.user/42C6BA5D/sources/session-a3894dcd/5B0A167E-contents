Finalize df by computing Nhat, TO, RIPA, SWA for each sample window:
----
<!---
NOTE:

    "Nhat" is the estimated dam count w/in sample window

    Computed as:
    
  $$\hat{N} = \displaystyle \frac{\sum(C)}{\mu(p)*(1-\mu(f))} $$

    Where:
    
    - $\hat{N}$ is the estimated dam count, given det. and fp det. probabilities
    - $\sum(C)$ is the sum of raw dam counts for all Thiessen polygons in a given sample window
    - $\mu(p)$ is the average detection probability for a given sample window
    - $\mu(f)$ is the average false positive probability for a given sample window
    
    [adapted from McCallum 2005; *Equation 1:* $\hat{N} = \displaystyle \frac{C}{\hat{p}}$; included term to consider false positive detection probability, and iterate across window[w]]
    
--->

```{r,echo=FALSE,warning=FALSE}
ubv21_sampled$clusterID_seq <- as.factor(ubv21_sampled$clusterID_seq)
ubv21_sampled$window_type <- as.factor(ubv21_sampled$window_type)

ubv21_final <- ubv21_sampled %>%
  select(clusterID_seq, 
         window_type,
         dam_count_beav_all,
         dam_count_beav_conf,
         dam_count_anthro,
         p,
         f, 
         TO,
         riparian_area_m2,
         starts_with("SWA_t"),
         starts_with("containsNull")
  ) %>%
  group_by(clusterID_seq, window_type) %>%
  summarize(
    # Nhat components
    sum_c = sum(dam_count_beav_all, na.rm = TRUE),
    mean_p = mean(p, na.rm = TRUE),
    mean_f = mean(f, na.rm = TRUE),
    Nhat = sum_c / (mean_p * (1 - mean_f)),

    # TO
    TO_mean = mean(TO, na.rm = TRUE),

    # Riparian area
    riparian_area_sum = sum(riparian_area_m2, na.rm = TRUE),

    # SWA across time periods
    across(starts_with("SWA_t"), ~ sum(.x, na.rm = TRUE), .names = "sum_{.col}"),

    # Null flag across ANY time period
    contains_null = any(c_across(starts_with("containsNull")) == 1),

    .groups = "drop"
  )


