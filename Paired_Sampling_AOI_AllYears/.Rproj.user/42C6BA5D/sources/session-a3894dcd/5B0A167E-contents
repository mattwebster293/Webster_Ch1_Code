DEFINE PAIRED UNDAMMED REACHES:
----

    - Undammed sample reaches must be:
      - interspersed between dammed reaches
      - (>=) 500m from nearest dam
      - 'paired' with a nearby dam cluster
      - (>=) 250m from nearest undammed (forced thinning post-pairing)

```{r,echo=FALSE}
lbv21_dam_min <- min(lbv21_dammed_df$TP_ID) #Find min/max dammed TP_ID to intersperse undammed among
lbv21_dam_max <- max(lbv21_dammed_df$TP_ID)



#Determine 500m buffers up and down from each dammed cluster; NO 'undammed' within this zone
lbv21_dam_influence_500 <- unique(unlist(
  apply(lbv21_dammed_df[, c("cluster_start", "cluster_end")], 1, function(row) {
    seq(row["cluster_start"] - 50,
        row["cluster_end"]   + 50)
  })
))    

#Get all available Riparian Polygons (excludes reservoir-affected)
lbv21_all_tpids <- sort(unique(lbv21_SWmax$TP_ID))  

#Ensure interspersion of undammed within dammed sites
lbv21_inRange_tpids <- lbv21_all_tpids[lbv21_all_tpids >= lbv21_dam_min & lbv21_all_tpids <= lbv21_dam_max]

#Get only riparian polygons that are not inside the dam or anthro influence zone (cluster+-500m)
lbv21_eligible_undammed_tpids <- lbv21_inRange_tpids[(!lbv21_inRange_tpids %in% lbv21_dam_influence_500) &
                                                     (!lbv21_inRange_tpids %in% lbv21_anthro_influence_500)]

#Get cluster start point for each dammed cluster
lbv21_dam_clusters <- lbv21_dammed_df %>%
  distinct(clusterID_seq, 
           cluster_start, 
           cluster_end, 
           cluster_dam_count) %>%
  arrange(clusterID_seq)


#PROXIMITY BASED PAIRING
#Define available undammed reaches to sample
lbv21_remaining_undammed <- lbv21_eligible_undammed_tpids

#Define undammed reaches that have been matched with dammed clusters
lbv21_assigned_matches <- integer(nrow(lbv21_dam_clusters)) #get 1 undammed for each dammed

# Iterate through dammed clusters
for (i in seq_len(nrow(lbv21_dam_clusters))) {
  # find cluster start
  cs <- lbv21_dam_clusters$cluster_start[i]
  
  # find nearest remaining undammed site
  idx <- which.min(abs(lbv21_remaining_undammed - cs))
  match <- lbv21_remaining_undammed[idx]
  
  lbv21_assigned_matches[i] <- match
  
  # remove it so it cannot be reused
  lbv21_remaining_undammed <- lbv21_remaining_undammed[-idx]
}

#Create table to visualize and gut check matches
lbv21_pairings <- lbv21_dam_clusters %>%
  mutate(undam_match = lbv21_assigned_matches) %>%
  left_join(lbv21_dammed_df %>%
              group_by(clusterID_seq) %>%
              summarise(dam_window_length_tpid = max(cluster_end) - min(cluster_start),
                        .groups = "drop"),
            by = "clusterID_seq") %>%
  mutate(undam_window_start = undam_match,
         undam_window_end   = undam_match + dam_window_length_tpid
  )

# THIN UNDAMMED WINDOWS *AFTER* WINDOW LENGTH IS KNOWN ---------------

lbv21_pairings <- lbv21_pairings %>% arrange(undam_window_start)

thinned <- list()
last_end <- -Inf

for (i in seq_len(nrow(lbv21_pairings))) {
  start_i <- lbv21_pairings$undam_window_start[i]
  end_i   <- lbv21_pairings$undam_window_end[i]
  
  if (start_i >= last_end + 25) {   # enforce 250-m spacing
    thinned <- append(thinned, i)   # NOTE: ^ no diff. than 100-m on lbv21
    last_end <- end_i
  }
}

lbv21_pairings <- lbv21_pairings[unlist(thinned), ]

# Now combine dammed and undammed windows into a unified table and select only those windows from the main dataframe
lbv21_dammed_windows <- lbv21_pairings %>%
  transmute(
    clusterID_seq,
    window_type = "dammed",
    window_start = cluster_start,
    window_end   = cluster_end,
    window_length = (window_end - window_start)*10,
    dam_intensity = cluster_dam_count
  )

lbv21_undammed_windows <- lbv21_pairings %>% 
  transmute(
    clusterID_seq,
    window_type = "undammed",
    window_start = undam_match,
    window_end   = undam_match + dam_window_length_tpid,
    window_length = dam_window_length_tpid * 10,
    dam_intensity = 0
  )

lbv21_all_windows <- bind_rows(
  lbv21_dammed_windows,
  lbv21_undammed_windows
)

lbv21_sampled <- lbv21_SWmax %>%
  cross_join(lbv21_all_windows) %>%   # explicit Cartesian join
  filter(
    TP_ID >= window_start,
    TP_ID <= window_end
  )
