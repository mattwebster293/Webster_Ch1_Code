  mutate(undam_match = lrb21_assigned_matches) %>%
  left_join(lrb21_dammed_df %>%
              group_by(clusterID_seq) %>%
              summarise(dam_window_length_tpid = max(cluster_end) - min(cluster_start),
                        .groups = "drop"),
            by = "clusterID_seq") %>%
  mutate(undam_window_start = undam_match,
         undam_window_end   = undam_match + dam_window_length_tpid
  )

# THIN UNDAMMED WINDOWS *AFTER* WINDOW LENGTH IS KNOWN ---------------

lrb21_pairings <- lrb21_pairings %>% arrange(undam_window_start)

thinned <- list()
last_end <- -Inf

for (i in seq_len(nrow(lrb21_pairings))) {
  start_i <- lrb21_pairings$undam_window_start[i]
  end_i   <- lrb21_pairings$undam_window_end[i]
  
  if (start_i >= last_end + 25) {   # enforce 250-m spacing
    thinned <- append(thinned, i)   # NOTE: ^ no diff. than 100-m on lrb21
    last_end <- end_i
  }
}

lrb21_pairings <- lrb21_pairings[unlist(thinned), ]

# Now combine dammed and undammed windows into a unified table and select only those windows from the main dataframe
lrb21_dammed_windows <- lrb21_pairings %>%
  transmute(
    clusterID_seq,
    window_type = "dammed",
    window_start = cluster_start,
    window_end   = cluster_end,
    window_length = (window_end - window_start)*10,
    dam_intensity = cluster_dam_count
  )

lrb21_undammed_windows <- lrb21_pairings %>% 
  transmute(
    clusterID_seq,
    window_type = "undammed",
    window_start = undam_match,
    window_end   = undam_match + dam_window_length_tpid,
    window_length = dam_window_length_tpid * 10,
    dam_intensity = 0
  )

lrb21_all_windows <- bind_rows(
  lrb21_dammed_windows,
  lrb21_undammed_windows
)

lrb21_sampled <- lrb21_SWmax %>%
  cross_join(lrb21_all_windows) %>%   # explicit Cartesian join
  filter(
    TP_ID >= window_start,
    TP_ID <= window_end
  )
