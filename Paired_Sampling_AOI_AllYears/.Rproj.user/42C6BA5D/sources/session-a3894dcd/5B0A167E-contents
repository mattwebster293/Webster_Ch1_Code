```{r,echo=FALSE}
lrb21_dam_min <- min(lrb21_dammed_df$TP_ID) #Find min/max dammed TP_ID to intersperse undammed among
lrb21_dam_max <- max(lrb21_dammed_df$TP_ID)



#Determine 500m buffers up and down from each dammed cluster; NO 'undammed' within this zone
lrb21_dam_influence_500 <- unique(unlist(
  apply(lrb21_dammed_df[, c("cluster_start", "cluster_end")], 1, function(row) {
    seq(row["cluster_start"] - 50,
        row["cluster_end"]   + 50)
  })
))    

#Get all available Riparian Polygons (excludes reservoir-affected)
lrb21_all_tpids <- sort(unique(lrb21_SWmax$TP_ID))  

#Ensure interspersion of undammed within dammed sites
lrb21_inRange_tpids <- lrb21_all_tpids[lrb21_all_tpids >= lrb21_dam_min & lrb21_all_tpids <= lrb21_dam_max]

#Get only riparian polygons that are not inside the dam or anthro influence zone (cluster+-500m)
lrb21_eligible_undammed_tpids <- lrb21_inRange_tpids[(!lrb21_inRange_tpids %in% lrb21_dam_influence_500) &
                                                     (!lrb21_inRange_tpids %in% lrb21_anthro_influence_500)]

#Get cluster start point for each dammed cluster
lrb21_dam_clusters <- lrb21_dammed_df %>%
  distinct(clusterID_seq, 
           cluster_start, 
           cluster_end, 
           cluster_dam_count) %>%
  arrange(clusterID_seq)


#PROXIMITY BASED PAIRING
#Define available undammed reaches to sample
lrb21_remaining_undammed <- lrb21_eligible_undammed_tpids

#Define undammed reaches that have been matched with dammed clusters
lrb21_assigned_matches <- integer(nrow(lrb21_dam_clusters)) #get 1 undammed for each dammed

# Iterate through dammed clusters
for (i in seq_len(nrow(lrb21_dam_clusters))) {
  # find cluster start
  cs <- lrb21_dam_clusters$cluster_start[i]
  
  # find nearest remaining undammed site
  idx <- which.min(abs(lrb21_remaining_undammed - cs))
  match <- lrb21_remaining_undammed[idx]
  
  lrb21_assigned_matches[i] <- match
  
  # remove it so it cannot be reused
  lrb21_remaining_undammed <- lrb21_remaining_undammed[-idx]
}

#Create table to visualize and gut check matches
