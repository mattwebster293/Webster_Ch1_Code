```{r,include=FALSE}
# ~~~~ 1-D K-Dist EPSILON OPTIMIZATION ~~~~~~~ #
# Rahmah and Sitanggang (2016)

# Function to compute 1-D k-distance (k = 2 recommended for minPts = 1)
lbv_compute_kdist_1d <- function(tp_ids, k = 2) {
  tp_ids <- sort(tp_ids)
  n <- length(tp_ids)
  kdist <- numeric(n)
  
  for (i in seq_len(n)) {
    dists <- abs(tp_ids[i] - tp_ids[-i])  # bidirectional 1-D distance
