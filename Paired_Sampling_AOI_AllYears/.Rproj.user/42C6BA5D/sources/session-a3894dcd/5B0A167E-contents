ubv21_dam_max <- max(ubv21_dammed_df$TP_ID)



#Determine 500m buffers up and down from each dammed cluster; NO 'undammed' within this zone
ubv21_dam_influence_500 <- unique(unlist(
  apply(ubv21_dammed_df[, c("cluster_start", "cluster_end")], 1, function(row) {
    seq(row["cluster_start"] - 50,
